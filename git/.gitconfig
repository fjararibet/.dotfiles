[user]
name = Felipe Jara
email = fjararibet@gmail.com
signingkey = ~/.ssh/id_ed25519.pub

[gpg]
format = ssh

[commit]
gpgsign = true

[tag]
gpgsign = true

[core]
editor = vim
autocrlf = input
pager = less -FRX

[pull]
ff = only

[push]
default = simple
autoSetupRemote = true

[init]
defaultBranch = main

[merge]
conflictstyle = zdiff3

[fetch]
prune = true
