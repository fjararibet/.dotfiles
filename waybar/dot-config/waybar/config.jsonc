{
  "layer": "top",
  "position": "bottom",
  "margin-top": -4,
  "margin-bottom": -2,
  "spacing" : 0,
  "modules-left": [
      "sway/workspaces",
  ],

  "modules-center": ["clock"],

  "modules-right": [
    // "bluetooth",
    "network",
    "pulseaudio", 
    "backlight",
    "battery",
    "custom/power",
  ],

  "sway/workspaces": {
    "disable-scroll": true,
    "disable-click": true,
    "all-outputs": true,
    "format": "{icon}",
    "format-icons": {
      "focused": "п†’",
      "default": "п„‘",
    },
    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
    }
  },

  "bluetooth": {
    "format": "у°‚І",
    "format-on": "{icon}",
    "format-off": "{icon}", 
    "format-connected":"{icon}",
    "format-icons":{
        "on":"у°‚Ї",
        "off": "у°‚І",
        "connected": "у°‚±",
        },
    // "on-click": "blueman-manager",
    "tooltip-format-connected":"{device_enumerate}"
  },

  "custom/music": {
    "format": "пЂЃ  {}",
    "escape": true,
    "interval": 5,
    "tooltip": false,
    "exec": "playerctl metadata --format='{{ artist }} - {{ title }}'",
    "on-click": "playerctl play-pause",
    "max-length": 50
  },

  "clock": {
    "timezone": "America/Santiago",
    "locale": "es_CL.utf8",
    "tooltip": true,
    "format": "{:L%H:%M - %A %d de %B}",
    "tooltip-format": "<tt><big>{calendar}</big></tt>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "format": {
        "months": "<span color='#c8c093'><b>{}</b></span>",
        "weekdays": "<span color='#99d1db'><b>{}</b></span>",
        "weeks": "<span color='#737994'>{}</span>",
        "today": "<span color='#1f1f28' background='#c8c093'><b>{}</b></span>"
      }
    },
    "actions": {
      "on-click": "mode",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    },
    "interval": 1
  },

  "network": {
    "format-wifi": "у°¤ў",
    "format-ethernet": "у°€Ђ",
    "format-disconnected": "у°¤ ",
    "interval": 5,
    "tooltip-format": "{essid} ({signalStrength}%)",
    "on-click": "nm-connection-editor"

 },

  "cpu": {
    "interval": 1,
    "format": "п‹›  {icon0}{icon1}{icon2}{icon3} {usage:>2}%",
    "format-icons": ["в–Ѓ", "в–‚", "в–ѓ", "в–„", "в–…", "в–†", "в–‡", "в–€"],
    "on-click": "alacritty -e htop"
  },

  "memory": {
    "interval": 30,
    "format": "ої…  {used:0.1f}G/{total:0.1f}G",
    "tooltip-format": "Memory"
  },

  "custom/uptime": {
    "format": "{}",
    "format-icon": ["пЃў"], 
    "tooltip": false,
    "interval": 1600,
    "exec": "$HOME/.config/waybar/scripts/uptime.sh"
  },
  
  "backlight": {
        "format": "{icon}  {percent}%",
        "format-icons": ["оЋЌ","у°ѓњ", "у°ѓ›", "у°ѓћ","у°ѓќ","у°ѓџ","у°ѓ "],
        "tooltip": false
  },
  
  "pulseaudio": {
    // Thin space keeps the icon close without visually merging it with the number.
    "format": "{icon}вЂ‰{volume}%",
    "format-muted": "п‘¦",
    "format-icons": {
      "default": "пЂ§"
    },
    "on-click": "pavucontrol"
  },

  "battery": {
        "interval":2,
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}  {capacity}%",
        "format-full": "{icon}  {capacity}%",
        "format-charging": "п‡¦ {capacity}%",
        "format-plugged": "п‡¦ {capacity}%",
        "format-alt": "{icon} {time}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["п‰„", "п‰ѓ", "п‰‚", "п‰Ѓ", "п‰Ђ"]
  },
  
  "custom/lock": {
  "tooltip": false,
  "on-click": "sh -c '(sleep 0s; hyprlock)' & disown",
  "format" : "пЂЈ"
  },

  "custom/power": {
      "format": "вЏ»",
      "on-click": "wlogout",
  },

  "custom/pomodoro": {
	"format": "{}",
	"return-type": "json",
	"exec": "waybar-module-pomodoro --no-work-icons",
	"on-click": "waybar-module-pomodoro toggle",
	"on-click-right": "waybar-module-pomodoro reset",
  },

}
